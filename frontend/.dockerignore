# frontend/.dockerignore

# 1. Secrets and Environment Variables (Security)
.env
.env.*

# 2. Local Dependencies (Performance & Determinism)
node_modules/

# 3. Local Build Outputs (Determinism)
dist/
build/

# 4. Tests and Testing Artifacts (Performance)
tests/
eslint.config.js
coverage/
playwright-report/
test-results/
blob-report/

# 5. OS and Version Control (Security & Cleanliness)
.git/
.DS_Store
Thumbs.db
.gitignore

# 6. Docker Files (Cleanliness)
Dockerfile*
.dockerignore

# 7. Develpmoent Files (Cleanliness)
setup-env*